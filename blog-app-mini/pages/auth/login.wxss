.login-container {
  padding: 40rpx 30rpx;
  height: 100vh;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
  padding-top: 100rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.sub-title {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.login-form {
  flex: 1;
}

.input-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 8rpx;
  padding: 0 20rpx;
  height: 88rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 100%;
}

.code-item {
  position: relative;
}

.code-input {
  padding-right: 180rpx;
}

.code-btn {
  position: absolute;
  right: 0;
  top: 0;
  width: 160rpx;
  height: 88rpx;
  background: transparent;
  color: #0088ff;
  font-size: 26rpx;
  border: none;
}

.code-btn[disabled] {
  color: #999;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #0088ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.login-btn[disabled] {
  background: #ccc;
}

.other-login {
  margin-top: 60rpx;
  text-align: center;
}

.other-login text {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.wx-login-btn {
  width: 80%;
  height: 80rpx;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.wx-icon {
  margin-right: 10rpx;
}