/* pages/detail/detail.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: auto;
}
.detail-wrap {
  background: #fff;
  margin: 16rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}
.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.detail-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  padding-bottom: 20rpx;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 20rpx;
}
.detail-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}
.detail-content rich-text {
  width: 100%;
}
.detail-content img {
  max-width: 100%;
  margin: 16rpx 0;
}
/* 评论区样式 */
.comment-wrap {
  background: #fff;
  margin: 16rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid #f0f0f0;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.refresh-btn {
  font-size: 26rpx;
  color: #0088ff;
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.comment-input {
  flex: 1;
  height: 70rpx;
  border: 1px solid #eee;
  border-radius: 35rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #0088ff;
  color: #fff;
  border-radius: 35rpx;
  font-size: 26rpx;
  padding: 0;
}

.send-btn[disabled] {
  background: #ccc;
}

.login-tip {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #0088ff;
}

.comment-list {
  margin-top: 20rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.comment-content {
  flex: 1;
}

.user-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.username {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.empty-comment {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}