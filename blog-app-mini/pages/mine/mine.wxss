.mine-container {
  padding: 0;
  height: 100vh;
  background-color: #f8f8f8;
}

/* 个人信息 */
.user-info-wrap {
  background: linear-gradient(135deg, #0088ff, #0066cc);
  padding: 60rpx 30rpx;
  display: flex;
  align-items: center;
  color: #fff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.phone {
  font-size: 26rpx;
  opacity: 0.8;
  display: block;
}

.logout-btn {
  width: 140rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.login-wrap {
  background: linear-gradient(135deg, #0088ff, #0066cc);
  padding: 100rpx 0;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
}

/* 功能列表 */
.func-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.func-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1px solid #f0f0f0;
}

.func-item:last-child {
  border-bottom: none;
}

.icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 24rpx;
  color: #999;
}